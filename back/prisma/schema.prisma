generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model tweet {
  idtweet Int       @id(map: "pk_tweet") @default(autoincrement())
  iduser  Int
  message String?   @db.VarChar(280)
  date    DateTime? @db.Date
  user    user      @relation(fields: [iduser], references: [iduser], onDelete: NoAction, onUpdate: NoAction, map: "fk_tweet_post_user")
}

model user {
  iduser         Int       @id(map: "pk_user") @default(autoincrement())
  nom            String?   @db.VarChar(15)
  phone          Int?
  mail           String?   @db.VarChar(100)
  verified       String?   @db.Bit(1)
  protected      String?   @db.Bit(1)
  creation       DateTime? @db.Date
  language       String?   @db.VarChar(50)
  gender         String?   @db.VarChar(50)
  birthdate      DateTime? @db.Date
  age            Int?
  profilepicture String?   @db.VarChar(100)
  banner         String?   @db.VarChar(100)
  bio            String?   @db.VarChar(100)
  tweet          tweet[]
}
